/**
  * @file    main.c
  * @brief   WiFi HTTP GET request demo for B-L475E-IOT01A
  *          Connects to WiFi and makes a GET request to example.com
  */

/* Includes ------------------------------------------------------------------*/
#include "main.h"
#include <string.h>
#include <stdio.h>

// config for network
#define SSID        "umd-iot"
#define PASSWORD    "cmAfMWG6VyDh"

#define WIFI_SOCKET       0
#define WIFI_READ_TIMEOUT  20000
#define WIFI_WRITE_TIMEOUT 10000

// server to connect to
#define TARGET_HOST  "httpbin.org"
#define TARGET_IP_0  54
#define TARGET_IP_1  204
#define TARGET_IP_2  10
#define TARGET_IP_3  1
#define TARGET_PORT  80

/* Private variables ---------------------------------------------------------*/
extern UART_HandleTypeDef hDiscoUart;

/* Printf retarget to UART -------------------------------------------------- */
#ifdef __GNUC__
int __io_putchar(int ch)
#else
int fputc(int ch, FILE *f)
#endif
{
  HAL_UART_Transmit(&hDiscoUart, (uint8_t *)&ch, 1, 0xFFFF);
  return ch;
}

/* Private function prototypes -----------------------------------------------*/
static void SystemClock_Config(void);
static int  wifi_connect(void);
static int  send_http_get(void);

/* ---------------------------------------------------------------------------*/
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  /* Init LED2: green = success, will toggle on error */
  BSP_LED_Init(LED2);

  /* Init UART for printf */
  hDiscoUart.Instance = DISCOVERY_COM1;
  hDiscoUart.Init.BaudRate = 115200;
  hDiscoUart.Init.WordLength = UART_WORDLENGTH_8B;
  hDiscoUart.Init.StopBits = UART_STOPBITS_1;
  hDiscoUart.Init.Parity = UART_PARITY_NONE;
  hDiscoUart.Init.Mode= UART_MODE_TX_RX;
  hDiscoUart.Init.HwFlowCtl= UART_HWCONTROL_NONE;
  hDiscoUart.Init.OverSampling= UART_OVERSAMPLING_16;
  hDiscoUart.Init.OneBitSampling= UART_ONE_BIT_SAMPLE_DISABLE;
  hDiscoUart.AdvancedInit.AdvFeatureInit= UART_ADVFEATURE_NO_INIT;
  BSP_COM_Init(COM1, &hDiscoUart);

  printf("\r\nWiFi GET Demo\r\n");

  /* Connect to WiFi */
  if (wifi_connect() != 0)
  {
    printf("WiFi connection failed. Halting.\r\n");
    while (1) { BSP_LED_Toggle(LED2); HAL_Delay(200); } /* fast blink = error */
  }

  /* Send GET request */
  if (send_http_get() != 0)
  {
    printf("HTTP GET failed.\r\n");
    while (1) { BSP_LED_Toggle(LED2); HAL_Delay(500); } /* slow blink = error */
  }

  /* Success — LED on solid */
  printf("\r\nDone! LED2 is now solid green.\r\n");
  BSP_LED_On(LED2);
  while (1) { }
}

/* ---------------------------------------------------------------------------
 * wifi_connect
 * Inits the ES-WiFi module, prints MAC address, joins the AP, prints IP.
 * ---------------------------------------------------------------------------*/
static int wifi_connect(void)
{
  uint8_t mac[6];
  uint8_t ip[4];

  printf("Initialising ES-WiFi module...\r\n");
  if (WIFI_Init() != WIFI_STATUS_OK)
  {
    printf("ERROR: WIFI_Init failed.\r\n");
    return -1;
  }

  /* MAC address is read from the module — no need to know it in advance */
  if (WIFI_GetMAC_Address(mac, sizeof(mac)) == WIFI_STATUS_OK)
  {
    printf("MAC Address : %02X:%02X:%02X:%02X:%02X:%02X\r\n",
           mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
  }
  else
  {
    printf("WARNING: Could not read MAC address.\r\n");
  }

  uint8_t fw_info[64];
  if (WIFI_GetModuleID(fw_info, sizeof(fw_info)) == WIFI_STATUS_OK)
      printf("Module ID: %s\r\n", (char*)fw_info);

  if (WIFI_GetModuleFwRevision(fw_info, sizeof(fw_info)) == WIFI_STATUS_OK)
      printf("FW Revision: %s\r\n", (char*)fw_info);

  printf("Connecting to SSID: %s ...\r\n", SSID);
  if (WIFI_Connect(SSID, PASSWORD, WIFI_ECN_WPA2_PSK) != WIFI_STATUS_OK)
  {
    printf("ERROR: Could not connect to AP.\r\n");
    return -1;
  }

  if (WIFI_GetIP_Address(ip, sizeof(ip)) != WIFI_STATUS_OK)
  {
    printf("ERROR: Could not get IP address.\r\n");
    return -1;
  }

  printf("Connected! IP Address: %d.%d.%d.%d\r\n", ip[0], ip[1], ip[2], ip[3]);
  return 0;
}

/* ---------------------------------------------------------------------------
 * send_http_get
 * Opens a TCP socket to example.com:80, sends a minimal HTTP/1.0 GET,
 * reads back the response, and prints it over UART.
 * ---------------------------------------------------------------------------*/
static int send_http_get(void)
{
  static const char request[] =
    "GET / HTTP/1.0\r\n"
    "Host: example.com\r\n"
    "\r\n";

  static uint8_t response[1200];  /* match ES_WIFI_PAYLOAD_SIZE exactly */
  uint16_t received = 0;
  uint8_t  remote_ip[4];

  /* Step 1: DNS lookup so we always have the correct IP */
  printf("Resolving example.com...\r\n");
  if (WIFI_GetHostAddress("example.com", remote_ip, sizeof(remote_ip)) != WIFI_STATUS_OK)
  {
      printf("DNS lookup failed, using hardcoded IP\r\n");
      remote_ip[0] = 93; remote_ip[1] = 184;
      remote_ip[2] = 216; remote_ip[3] = 34;
  }
  printf("Resolved to: %d.%d.%d.%d\r\n",
         remote_ip[0], remote_ip[1], remote_ip[2], remote_ip[3]);

  /* Step 2: Open connection */
  printf("Opening connection...\r\n");
  if (WIFI_OpenClientConnection(WIFI_SOCKET, WIFI_TCP_PROTOCOL,
                                "example.com", remote_ip, 80, 0) != WIFI_STATUS_OK)
  {
    printf("ERROR: Cannot open connection\r\n");
    return -1;
  }
  printf("Connected!\r\n");

  /* Step 3: Send — request length must be even for the ISM43362 driver */
  uint16_t req_len = strlen(request);
  printf("Request length: %d bytes\r\n", req_len);

  /* Pad to even length if needed */
  static char padded_request[128];
  memcpy(padded_request, request, req_len);
  if (req_len & 1)
  {
    padded_request[req_len++] = ' ';  /* pad with a space — harmless in HTTP */
  }

  uint16_t sent = 0;
  if (WIFI_SendData(WIFI_SOCKET, (uint8_t *)padded_request,
                    req_len, &sent, WIFI_WRITE_TIMEOUT) != WIFI_STATUS_OK)
  {
    printf("ERROR: Send failed\r\n");
    WIFI_CloseClientConnection(WIFI_SOCKET);
    return -1;
  }
  printf("Sent %d bytes\r\n", sent);

  /* Step 4: Read response in chunks of 1200 (ES_WIFI_PAYLOAD_SIZE) */
  uint16_t total = 0;
  int attempts = 0;
  printf("Reading response...\r\n");

  while (attempts < 10)
  {
    received = 0;
    WIFI_Status_t ret = WIFI_ReceiveData(WIFI_SOCKET,
                                         response,
                                         sizeof(response),
                                         &received,
                                         10000);
    printf("Attempt %d: ret=%d received=%d\r\n", attempts+1, ret, received);

    if (received > 0)
    {
      response[received] = '\0';
      printf("%s", (char*)response);
      total += received;
    }

    if (ret != WIFI_STATUS_OK || received == 0)
      break;

    attempts++;
  }

  printf("\r\n--- Total: %d bytes ---\r\n", total);
  WIFI_CloseClientConnection(WIFI_SOCKET);
  return (total > 0) ? 0 : -1;
}

