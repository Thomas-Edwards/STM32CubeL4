/* Network config ------------------------------------------------------------*/
#define SSID               "Thomas Edwards"
#define PASSWORD           "your_hotspot_password"

#define WIFI_SOCKET        0
#define WIFI_READ_TIMEOUT  20000
#define WIFI_WRITE_TIMEOUT 10000

#define TARGET_HOST        "example.com"
#define TARGET_PORT        80

/* Audio/FFT config ----------------------------------------------------------*/
#define BUFFER_SIZE        2048
#define LED_MAX_DUTY       999

/* Private variables ---------------------------------------------------------*/
extern UART_HandleTypeDef hDiscoUart;

/* DFSDM handles — defined here since we have no dfsdm.c yet */
DFSDM_Filter_HandleTypeDef  hdfsdm1_filter0;
DFSDM_Channel_HandleTypeDef hdfsdm1_channel2;
DMA_HandleTypeDef           hdma_dfsdm1_flt0;

/* TIM handle */
TIM_HandleTypeDef htim2;

/* Audio buffers */
volatile uint8_t  data_ready_flag = 0;
__attribute__((aligned(4))) volatile int32_t  ringbuffer[BUFFER_SIZE];
__attribute__((aligned(4))) float32_t         fft_input[BUFFER_SIZE/2];
__attribute__((aligned(4))) float32_t         fft_output[BUFFER_SIZE];
__attribute__((aligned(4))) float32_t         to_send[BUFFER_SIZE/2];
arm_rfft_fast_instance_f32  fft_handler;

/* Printf retarget -----------------------------------------------------------*/
#ifdef __GNUC__
int __io_putchar(int ch)
#else
int fputc(int ch, FILE *f)
#endif
{
  HAL_UART_Transmit(&hDiscoUart, (uint8_t *)&ch, 1, 0xFFFF);
  return ch;
}

/* Function prototypes -------------------------------------------------------*/
static void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_DMA_Init(void);
static void MX_DFSDM1_Init(void);
static void MX_TIM2_Init(void);
static int  wifi_connect(void);
static int  send_http_get(void);
static void Process_Audio_Data(uint32_t start_index, uint32_t length);

/* DMA callbacks -------------------------------------------------------------*/
void HAL_DFSDM_FilterRegConvHalfCpltCallback(DFSDM_Filter_HandleTypeDef *hdfsdm_filter)
{
  data_ready_flag = 1;
}

void HAL_DFSDM_FilterRegConvCpltCallback(DFSDM_Filter_HandleTypeDef *hdfsdm_filter)
{
  data_ready_flag = 2;
}

/* Audio processing ----------------------------------------------------------*/
static void Process_Audio_Data(uint32_t start_index, uint32_t length)
{
  int64_t dc_sum = 0;
  for (uint32_t i = start_index; i < (start_index + length); i++) {
    dc_sum += ringbuffer[i];
  }
  float32_t dc_offset = (float32_t)(dc_sum) / length;

  for (uint32_t i = 0; i < length; i++) {
    fft_input[i] = (float32_t)ringbuffer[i + start_index] - dc_offset;
  }

  arm_rfft_fast_f32(&fft_handler, fft_input, fft_output, 0);
  arm_cmplx_mag_f32(fft_output, to_send, BUFFER_SIZE/2);
  to_send[0] = 0;

  // SEND HERE
}

/* Main ----------------------------------------------------------------------*/
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  /* Init peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_DFSDM1_Init();
  MX_TIM2_Init();

  BSP_LED_Init(LED2);

  /* Init UART for printf */
  hDiscoUart.Instance                    = DISCOVERY_COM1;
  hDiscoUart.Init.BaudRate               = 115200;
  hDiscoUart.Init.WordLength             = UART_WORDLENGTH_8B;
  hDiscoUart.Init.StopBits               = UART_STOPBITS_1;
  hDiscoUart.Init.Parity                 = UART_PARITY_NONE;
  hDiscoUart.Init.Mode                   = UART_MODE_TX_RX;
  hDiscoUart.Init.HwFlowCtl              = UART_HWCONTROL_NONE;
  hDiscoUart.Init.OverSampling           = UART_OVERSAMPLING_16;
  hDiscoUart.Init.OneBitSampling         = UART_ONE_BIT_SAMPLE_DISABLE;
  hDiscoUart.AdvancedInit.AdvFeatureInit = UART_ADVFEATURE_NO_INIT;
  BSP_COM_Init(COM1, &hDiscoUart);

  printf("\r\nWiFi + Audio Demo\r\n");

  /* Init FFT */
  arm_rfft_fast_init_f32(&fft_handler, BUFFER_SIZE/2);

  /* Start PWM and DFSDM DMA */
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
  HAL_DFSDM_FilterRegularStart_DMA(&hdfsdm1_filter0,
                                    (int32_t *)ringbuffer,
                                    BUFFER_SIZE);

  /* Connect to WiFi */
  if (wifi_connect() != 0)
  {
    printf("WiFi failed.\r\n");
    while (1) { BSP_LED_Toggle(LED2); HAL_Delay(200); }
  }

  /* Test GET request */
  if (send_http_get() != 0)
  {
    printf("HTTP GET failed.\r\n");
    while (1) { BSP_LED_Toggle(LED2); HAL_Delay(500); }
  }

  BSP_LED_On(LED2);
  printf("Done! Running audio loop.\r\n");

  /* Main loop — process audio */
  volatile uint8_t temp;
  while (1)
  {
    temp = data_ready_flag;
    data_ready_flag = 0;

    if (temp == 1) Process_Audio_Data(0, BUFFER_SIZE/2);
    if (temp == 2) Process_Audio_Data(BUFFER_SIZE/2, BUFFER_SIZE/2);
  }
}

/* WiFi functions ------------------------------------------------------------*/
static int wifi_connect(void)
{
  uint8_t mac[6];
  uint8_t ip[4];
  uint8_t fw_info[64];

  printf("Initialising ES-WiFi module...\r\n");
  if (WIFI_Init() != WIFI_STATUS_OK)
  {
    printf("ERROR: WIFI_Init failed.\r\n");
    return -1;
  }

  if (WIFI_GetMAC_Address(mac, sizeof(mac)) == WIFI_STATUS_OK)
    printf("MAC Address : %02X:%02X:%02X:%02X:%02X:%02X\r\n",
           mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);

  if (WIFI_GetModuleID(fw_info, sizeof(fw_info)) == WIFI_STATUS_OK)
    printf("Module ID: %s\r\n", (char*)fw_info);

  if (WIFI_GetModuleFwRevision(fw_info, sizeof(fw_info)) == WIFI_STATUS_OK)
    printf("FW Revision: %s\r\n", (char*)fw_info);

  printf("Connecting to SSID: %s ...\r\n", SSID);
  if (WIFI_Connect(SSID, PASSWORD, WIFI_ECN_WPA2_PSK) != WIFI_STATUS_OK)
  {
    printf("ERROR: Could not connect to AP.\r\n");
    return -1;
  }

  if (WIFI_GetIP_Address(ip, sizeof(ip)) != WIFI_STATUS_OK)
  {
    printf("ERROR: Could not get IP address.\r\n");
    return -1;
  }

  printf("Connected! IP: %d.%d.%d.%d\r\n", ip[0], ip[1], ip[2], ip[3]);
  return 0;
}

static int send_http_get(void)
{
  static const char request[] =
    "GET / HTTP/1.0\r\n"
    "Host: example.com\r\n"
    "\r\n";

  static uint8_t response[1200];
  uint16_t received = 0;
  uint8_t  remote_ip[4];

  printf("Resolving %s...\r\n", TARGET_HOST);
  if (WIFI_GetHostAddress(TARGET_HOST, remote_ip, sizeof(remote_ip)) != WIFI_STATUS_OK)
  {
    remote_ip[0] = 93; remote_ip[1] = 184;
    remote_ip[2] = 216; remote_ip[3] = 34;
  }
  printf("Resolved to: %d.%d.%d.%d\r\n",
         remote_ip[0], remote_ip[1], remote_ip[2], remote_ip[3]);

  if (WIFI_OpenClientConnection(WIFI_SOCKET, WIFI_TCP_PROTOCOL,
                                TARGET_HOST, remote_ip,
                                TARGET_PORT, 0) != WIFI_STATUS_OK)
  {
    printf("ERROR: Cannot open connection\r\n");
    return -1;
  }

  uint16_t req_len = strlen(request);
  static char padded_request[128];
  memcpy(padded_request, request, req_len);
  if (req_len & 1) padded_request[req_len++] = ' ';

  uint16_t sent = 0;
  if (WIFI_SendData(WIFI_SOCKET, (uint8_t *)padded_request,
                    req_len, &sent, WIFI_WRITE_TIMEOUT) != WIFI_STATUS_OK)
  {
    printf("ERROR: Send failed\r\n");
    WIFI_CloseClientConnection(WIFI_SOCKET);
    return -1;
  }

  uint16_t total = 0;
  int attempts = 0;
  while (attempts < 10)
  {
    received = 0;
    WIFI_Status_t ret = WIFI_ReceiveData(WIFI_SOCKET, response,
                                          sizeof(response), &received, 10000);
    if (received > 0)
    {
      response[received] = '\0';
      printf("%s", (char*)response);
      total += received;
    }
    if (ret != WIFI_STATUS_OK || received == 0) break;
    attempts++;
  }

  printf("\r\n--- Total: %d bytes ---\r\n", total);
  WIFI_CloseClientConnection(WIFI_SOCKET);
  return (total > 0) ? 0 : -1;
}

